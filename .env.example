# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_UPGRADE_URL=https://t.me/YourUpgradeBot

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0

# ─── Database ───────────────────────────────────────────────
# SQLite (local / Railway)
DATABASE_URL=file:./prisma/prod.db

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated extra origins allowed in production
# (*.vercel.app and *.t.me are allowed by default)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_CALLS_PER_DAY=50

# ─── Admin ───────────────────────────────────────────────────
ADMIN_KEY=secret-admin-2025

# ─── Dev Only (do NOT set in production) ────────────────────
# LOCAL_DEV_BYPASS=true
# MOCK_CLAUDE=true
